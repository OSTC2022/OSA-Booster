# Supabase — get these from:
# https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — never expose to the browser (Settings > API > service_role)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public app URL for invite / email links
# Local: http://localhost:3000
# Vercel Production (one-step-coach-hlbv):
NEXT_PUBLIC_SITE_URL=https://one-step-coach-hlbv.vercel.app

# 비밀번호 재설정 메일 (네이버 등) — Supabase SMTP 대신 앱에서 직접 발송
# 네이버: 2단계 인증 + 애플리케이션 비밀번호 필수 (일반 비밀번호 X)
SMTP_HOST=smtp.naver.com
SMTP_PORT=465
SMTP_USER=your-id@naver.com
SMTP_PASS=your-naver-application-password
SMTP_FROM=your-id@naver.com
SMTP_FROM_NAME=OneStep Coach

# Google Calendar 연동 (센터 공용 · 수업/수업2 캘린더)
# Google Cloud Console > API 및 서비스 > OAuth 클라이언트 ID (웹)
# Calendar API 활성화 · redirect URI: {SITE_URL}/auth/google/calendar/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Push webhook 검증용 임의 문자열 (openssl rand -hex 32)
GOOGLE_CALENDAR_WEBHOOK_SECRET=

# (선택) 러닝 스크린샷 OpenAI Vision 폴백 — 기본 OFF (브라우저 Tesseract OCR 사용)
# NEXT_PUBLIC_ENABLE_OPENAI_SCREENSHOT_FALLBACK=true
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o-mini
# Vercel Pro 등 — AI 타임아웃(ms). Hobby(10초)는 기본 8000 사용
# SCREENSHOT_AI_TIMEOUT_MS=20000
# TEMPORARY DEBUG — set to true only while verifying key on Vercel, then remove
ENABLE_OPENAI_ENV_DEBUG=
# FOOD_DATABASE_URL=https://your-food-project.supabase.co
# FOOD_DATABASE_ANON_KEY=your-food-anon-key
